# ApplyTex Environment Configuration
# Copy to ~/.applytex/.env and fill in your keys.

# LLM (Tier 2+) — pick one provider
#
# DeepSeek (Anthropic-compatible) — copy to ~/.applytex/.env:
# ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic
# ANTHROPIC_AUTH_TOKEN=your_deepseek_api_key
# ANTHROPIC_DEFAULT_SONNET_MODEL=deepseek-v4-flash
#
# GEMINI_API_KEY=
# OPENAI_API_KEY=
# LLM_URL=http://localhost:11434/v1
# LLM_MODEL=gemini-2.0-flash

# Auto-apply (Tier 3, optional)
# CAPSOLVER_API_KEY=

# Override data directory (optional)
# APPLYTEX_DIR=~/.applytex
